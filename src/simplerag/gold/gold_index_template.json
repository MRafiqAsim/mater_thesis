{
  "_description": "Gold Layer Index Template - RAG Retrieval with Full Lineage",
  "_purpose": "Vector index for semantic search with support for SimpleRAG, PathRAG, GraphRAG",

  "chunk_index": {
    "_location": "gold/index/chunks.json",
    "_description": "All indexed chunks with metadata",
    "chunk_id": {
      "chunk_id": "bronze_xxx_chunk_0",
      "text": "Chunk text for retrieval",
      "word_count": 100,

      "email_id": "bronze_xxx (lineage to Bronze)",
      "silver_id": "silver_bronze_xxx (lineage to Silver)",
      "source_file": "original.pst",

      "subject": "Email subject for context",
      "timestamp": "ISO-8601",
      "sender_email": "sender@domain.com",
      "sender_domain": "domain.com (for GraphRAG filtering)",
      "thread_id": "thread_xxx (for PathRAG filtering)",
      "message_id": "<unique-id@domain>",
      "is_reply": true
    }
  },

  "embeddings": {
    "_location": "gold/embeddings/embeddings.npz",
    "_description": "NumPy array of embeddings",
    "embeddings": "np.ndarray shape (num_chunks, embedding_dim)",
    "ids": "np.array of chunk_ids in same order"
  },

  "secondary_indices": {
    "_location": "gold/index/secondary_indices.json",
    "_description": "Indices for PathRAG and GraphRAG filtering",
    "thread_index": {
      "thread_xxx": ["chunk_id_1", "chunk_id_2"],
      "_description": "Map thread_id to chunk_ids for PathRAG"
    },
    "sender_index": {
      "domain.com": ["chunk_id_1", "chunk_id_3"],
      "_description": "Map sender_domain to chunk_ids for GraphRAG"
    }
  },

  "query_response": {
    "_description": "Structure of RAG query response",
    "query": "User's question",
    "answer": "Generated answer with [Source X] citations",
    "sources": [
      {
        "chunk_id": "bronze_xxx_chunk_0",
        "text_preview": "First 200 chars...",
        "score": 0.8765,
        "subject": "Email subject",
        "timestamp": "2013-12-18T10:03:48",
        "sender": "sender@domain.com",
        "email_id": "bronze_xxx"
      }
    ],
    "lineage": [
      {
        "chunk_id": "bronze_xxx_chunk_0",
        "email_id": "bronze_xxx",
        "silver_id": "silver_bronze_xxx",
        "source_file": "original.pst"
      }
    ],
    "is_grounded": true,
    "confidence": 0.85,
    "missing_info": "null or description of missing info",
    "model_info": {
      "model": "gpt-4o",
      "version": "2024-02-15",
      "prompt_version": "v1.0"
    },
    "timestamp": "ISO-8601"
  },

  "query_modes": {
    "SimpleRAG": {
      "description": "Basic vector similarity search across all chunks",
      "usage": "query(question, top_k=10)"
    },
    "PathRAG": {
      "description": "Filter to specific conversation thread",
      "usage": "query(question, thread_id='thread_xxx')"
    },
    "GraphRAG": {
      "description": "Filter to specific sender domain/organization",
      "usage": "query(question, sender_domain='company.com')"
    }
  }
}
