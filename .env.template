# Pipeline Configuration
PIPELINE_MODE=openai

# OpenAI Configuration (fill in your credentials)

# Azure OpenAI Configuration (alternative - fill if using Azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# Azure OpenAI Embedding Configuration
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Retrieval Configuration
# GraphRAG search type: auto (query-based routing), global (map-reduce, thorough), local (entity-centric, fast)
GRAPHRAG_SEARCH_TYPE=auto

# Azure AI Search (for hybrid vector+keyword search)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=

# Cosmos DB — Gremlin API (knowledge graph)
COSMOS_GREMLIN_ENDPOINT=
COSMOS_GREMLIN_KEY=
COSMOS_DATABASE=email-kg
COSMOS_GRAPH=knowledge-graph

# Cosmos DB — NoSQL API (chunks, communities, thread summaries)
COSMOS_NOSQL_ENDPOINT=
COSMOS_NOSQL_KEY=

# ADLS Gen2 (Synapse pipeline)
ADLS_STORAGE_ACCOUNT=
ADLS_CONTAINER=pipeline-data
ADLS_STORAGE_KEY=

# Processing Limits
PROCESS_THRESHOLD=20
PROCESS_ANONYMIZATION_SUMMARIZATION_TOGETHER=true
