# =============================================================================
# Pipeline Configuration
# =============================================================================

# Processing mode: openai (default), local, or hybrid
# - openai: Use OpenAI API for PII detection, anonymization, and summarization
# - local: Use local models only (Presidio/spaCy/regex) - no summarization
# - hybrid: Local for high-confidence, OpenAI for complex cases
PIPELINE_MODE=openai

# =============================================================================
# OpenAI Configuration (for OPENAI and HYBRID modes)
# =============================================================================

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Azure OpenAI Configuration (alternative to OpenAI)
# =============================================================================

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_GPT4O_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# =============================================================================
# Azure Storage (ADLS Gen2)
# =============================================================================

AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_CONTAINER_NAME=knowledge-lake
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key

# =============================================================================
# Azure AI Search
# =============================================================================

AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-key

# =============================================================================
# Azure Cosmos DB (Gremlin) - for Knowledge Graph
# =============================================================================

AZURE_COSMOS_ENDPOINT=wss://your-cosmos.gremlin.cosmos.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-key
AZURE_COSMOS_DATABASE=knowledge-graph
AZURE_COSMOS_GRAPH=entities

# =============================================================================
# Data Paths
# =============================================================================

BRONZE_PATH=./data/bronze
SILVER_PATH=./data/silver
GOLD_PATH=./data/gold

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO
