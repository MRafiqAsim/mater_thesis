{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "silver_chunk.json",
  "title": "Silver Thread Chunk",
  "description": "Schema for anonymized, chunked email threads in the Silver layer",
  "type": "object",
  "required": [
    "chunk_id",
    "thread_id",
    "chunk_index",
    "text_original",
    "text_anonymized",
    "token_count",
    "thread_subject",
    "thread_email_count",
    "language",
    "processing_mode"
  ],
  "properties": {
    "chunk_id": {
      "type": "string",
      "description": "Unique chunk identifier: {thread_id}_{chunk_index}"
    },
    "thread_id": {
      "type": "string",
      "description": "Parent thread identifier"
    },
    "chunk_index": {
      "type": "integer",
      "minimum": 0,
      "description": "Position within the thread's chunks"
    },
    "text_original": {
      "type": "string",
      "description": "Original text before anonymization"
    },
    "text_anonymized": {
      "type": "string",
      "description": "Text with PII replaced by pseudonyms"
    },
    "token_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Token count of the chunk"
    },
    "thread_subject": {
      "type": "string",
      "description": "Normalized thread subject"
    },
    "thread_participants": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of thread participants (anonymized)"
    },
    "thread_email_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of emails in the thread"
    },
    "email_position": {
      "type": "string",
      "description": "Position indicator (e.g., '1/5', 'thread_3_emails')"
    },
    "pii_entities": {
      "type": "array",
      "description": "Detected PII entities with metadata",
      "items": {
        "type": "object",
        "required": ["text", "type", "start", "end", "confidence", "method"],
        "properties": {
          "text": { "type": "string" },
          "type": { "type": "string", "enum": ["PERSON", "EMAIL", "PHONE", "ADDRESS", "IBAN", "CREDIT_CARD", "SSN", "BSN", "IP_ADDRESS", "URL", "LOCATION", "ORGANIZATION", "ID_NUMBER", "LICENSE_PLATE", "PASSPORT", "DATE_OF_BIRTH"] },
          "start": { "type": "integer" },
          "end": { "type": "integer" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "method": { "type": "string" }
        }
      }
    },
    "pii_count": {
      "type": "integer",
      "minimum": 0
    },
    "kg_entities": {
      "type": "array",
      "description": "Knowledge graph entities for PathRAG",
      "items": { "type": "object" }
    },
    "kg_relationships": {
      "type": "array",
      "description": "Knowledge graph relationships for PathRAG",
      "items": { "type": "object" }
    },
    "has_attachments": { "type": "boolean" },
    "attachment_count": { "type": "integer", "minimum": 0 },
    "attachment_filenames": {
      "type": "array",
      "items": { "type": "string" }
    },
    "language": {
      "type": "string",
      "description": "Detected language code (en, nl)"
    },
    "processing_mode": {
      "type": "string",
      "enum": ["local", "llm", "hybrid"],
      "description": "Pipeline processing mode used to produce this chunk"
    },
    "processing_time": {
      "type": "string",
      "format": "date-time"
    }
  }
}
