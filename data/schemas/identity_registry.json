{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "identity_registry.json",
  "title": "Identity Registry",
  "description": "Schema for the identity registry that maps email addresses to canonical identities for consistent anonymization",
  "type": "object",
  "required": ["version", "identities", "build_stats"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Registry schema version",
      "const": "1.0"
    },
    "build_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the registry was last built"
    },
    "identities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Identity"
      }
    },
    "build_stats": {
      "type": "object",
      "properties": {
        "total_identities": { "type": "integer", "minimum": 0 },
        "total_aliases": { "type": "integer", "minimum": 0 },
        "total_emails_scanned": { "type": "integer", "minimum": 0 },
        "build_time_seconds": { "type": "number" }
      }
    }
  },
  "$defs": {
    "Identity": {
      "type": "object",
      "required": ["email_address", "canonical_name", "pseudonym_id"],
      "properties": {
        "email_address": {
          "type": "string",
          "format": "email",
          "description": "Primary key — lowercase email address"
        },
        "canonical_name": {
          "type": "string",
          "description": "Longest observed display name for this person"
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "All name variations observed for this person"
        },
        "pseudonym_id": {
          "type": "string",
          "pattern": "^PERSON_\\d{3,}$",
          "description": "Stable pseudonym used across all anonymization (e.g., PERSON_001)"
        },
        "email_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of emails sent by this identity"
        }
      }
    }
  }
}
